{
  "manifest_version": 3,
  "name": "LeetCode Mentor",
  "version": "1.0",
  "description": "An injected, empathetic AI coding assistant that guides you to the optimal solution without giving away the code.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}